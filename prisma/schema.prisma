generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ShowHnPost {
  id             Int      @id @default(autoincrement())
  hnId           String   @unique
  title          String
  summary        String
  url            String
  numComments    Int
  upvotes        Int
  postedAt       DateTime
  createdAt      DateTime @default(now())
  aiSummary      String?
  aiScore        Int?
  aiScoreDetails Json?
  previewImage   String?
  previewFetchedAt DateTime?
  siteDescription String?
  rating         UserRating?
}

model UserRating {
  id        Int        @id @default(autoincrement())
  postId    Int        @unique
  post      ShowHnPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  value     Int
  reason    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
